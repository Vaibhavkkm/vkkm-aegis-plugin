{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "VKKM Aegis Plugin Manifest",
    "description": "JSON Schema for .claude-plugin/plugin.json validation",
    "type": "object",
    "required": [
        "name",
        "author",
        "version",
        "description",
        "slash_commands",
        "system_prompt_path"
    ],
    "additionalProperties": true,
    "properties": {
        "$schema": {
            "type": "string"
        },
        "name": {
            "type": "string",
            "const": "VKKM Aegis",
            "description": "Plugin display name"
        },
        "author": {
            "type": "string",
            "description": "Plugin author handle"
        },
        "website": {
            "type": "string",
            "format": "uri",
            "description": "Author website URL"
        },
        "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+(\\.\\d+)?$",
            "description": "Semantic version string"
        },
        "description": {
            "type": "string",
            "minLength": 20,
            "description": "Plugin description"
        },
        "trustworthiness_rating": {
            "type": "string",
            "description": "Reliability rating out of 10"
        },
        "compatible_models": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "string"
            },
            "description": "List of compatible Claude model identifiers"
        },
        "slash_commands": {
            "type": "array",
            "minItems": 6,
            "items": {
                "type": "string",
                "pattern": "^/vkkm:[a-z-]+$"
            },
            "description": "List of slash commands this plugin provides"
        },
        "command_specs": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "command",
                    "spec_file",
                    "reliability",
                    "description"
                ],
                "properties": {
                    "command": {
                        "type": "string"
                    },
                    "spec_file": {
                        "type": "string"
                    },
                    "reliability": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    }
                }
            }
        },
        "skills": {
            "type": "array",
            "minItems": 5,
            "items": {
                "type": "string"
            }
        },
        "skills_paths": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "system_prompt_path": {
            "type": "string",
            "description": "Relative path to the master system prompt file"
        },
        "system_prompt": {
            "type": "string",
            "description": "Inline system prompt (excerpt or full)"
        },
        "opening_message": {
            "type": "string",
            "description": "Message shown when plugin activates"
        },
        "standard": {
            "type": "string",
            "description": "Risk management standard applied (e.g. ISO 31000)"
        },
        "created": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "Creation date ISO 8601"
        }
    }
}